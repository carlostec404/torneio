# =========================================================================
# Variáveis de ambiente para o VPS (Hostinger / Node.js)
# Copie este arquivo para `.env` no servidor: cp .env.production.example .env
# NUNCA faça commit do .env real no Git.
# =========================================================================

# --- Servidor Node ---
NODE_ENV=production
PORT=3000
HOST=127.0.0.1

# --- Lovable Cloud (backend) ---
# Estes valores são os mesmos do arquivo .env que já existe no projeto.
# Pegue os valores reais no painel da Lovable (Cloud > Settings) ou no .env local.
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOi...
VITE_SUPABASE_PROJECT_ID=seu-project-id

# Versões server-side (mesmos valores, sem o prefixo VITE_)
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_PUBLISHABLE_KEY=eyJhbGciOi...

# Chave de serviço (NUNCA exponha publicamente — só backend)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# --- Lovable AI Gateway (se usado) ---
LOVABLE_API_KEY=

# --- Stripe (pagamentos) ---
STRIPE_SANDBOX_API_KEY=sk_test_...
PAYMENTS_SANDBOX_WEBHOOK_SECRET=whsec_...
