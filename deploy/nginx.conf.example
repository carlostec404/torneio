# /etc/nginx/sites-available/torneio-manoamano
# Depois: ln -s /etc/nginx/sites-available/torneio-manoamano /etc/nginx/sites-enabled/
#         nginx -t && systemctl reload nginx
# E em seguida: certbot --nginx -d seudominio.com -d www.seudominio.com

server {
    listen 80;
    listen [::]:80;
    server_name seudominio.com www.seudominio.com;

    # Limite de upload (comprovantes de pagamento)
    client_max_body_size 10M;

    # Proxy reverso para o Node (PM2) rodando na porta 3000
    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;

        # Headers padrão
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host  $host;

        # Suporte a WebSocket (realtime do Lovable Cloud)
        proxy_set_header Upgrade           $http_upgrade;
        proxy_set_header Connection        "upgrade";

        # Timeouts generosos para SSR / uploads
        proxy_read_timeout  300s;
        proxy_send_timeout  300s;
        proxy_connect_timeout 60s;

        # Buffer
        proxy_buffering off;
    }
}
